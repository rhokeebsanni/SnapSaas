# Normalize line endings to LF in the repository for cross-platform consistency.
* text=auto eol=lf

# Shell hooks must stay LF so they run on Linux CI runners.
.husky/** text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.woff binary
*.woff2 binary
