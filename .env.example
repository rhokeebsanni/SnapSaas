# =============================================================================
# SnapSaas — Environment variables
# -----------------------------------------------------------------------------
# 1. Copy this file:                cp .env.example .env
# 2. Fill in the values below. Every variable says exactly where to get it.
# 3. To just run sign-up locally you only NEED: DATABASE_URL + BETTER_AUTH_SECRET.
#    Everything else turns its feature on when you add it (and stays off if blank).
#
# Never commit `.env` (it's gitignored). NEXT_PUBLIC_* values are exposed to the
# browser — never put secrets in those.
# =============================================================================


# -----------------------------------------------------------------------------
# Core / app URLs
# -----------------------------------------------------------------------------

# The public URL of the web app.
# Local dev: leave as-is. Production: your Vercel URL, e.g. https://snapsaas.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Where the web app reaches the screenshot worker (server-side only).
# Local dev: leave as-is. Production: the worker's public URL from Railway/Fly.
WORKER_URL="http://localhost:4000"

# Dev-only: allow capturing localhost / private network addresses. This DISABLES
# the SSRF guard, so set it to "true" only for local development and NEVER in
# production (leave it unset/blank in prod).
ALLOW_LOCAL_CAPTURE=""

# A shared secret so the web app and worker can trust each other's calls.
# Generate one (any long random string) and use the SAME value in web + worker:
#   node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
INTERNAL_API_SECRET="change-me-to-a-long-random-string"


# -----------------------------------------------------------------------------
# Database — Neon (serverless Postgres)   [REQUIRED for sign-up to work]
# -----------------------------------------------------------------------------
# Where to get it:
#   1. Create a free project at https://neon.tech
#   2. On the project dashboard click "Connect"
#   3. Copy the "Pooled connection" string (keep ?sslmode=require)
# After setting this, run:  npm run db:migrate   (creates the tables)
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.neon.tech/neondb?sslmode=require"


# -----------------------------------------------------------------------------
# Auth — Better Auth   [BETTER_AUTH_SECRET is REQUIRED]
# -----------------------------------------------------------------------------
# Generate the secret (any long random string):
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
BETTER_AUTH_SECRET="generate-a-long-random-string"

# Same as NEXT_PUBLIC_APP_URL (http://localhost:3000 locally, your domain in prod).
BETTER_AUTH_URL="http://localhost:3000"

# Require users to verify their email before they can sign in. Defaults to TRUE.
# IMPORTANT: this needs RESEND_API_KEY (below) set, or the verification email
# can't send and users get locked out. For local dev before Resend is configured,
# set this to "false" so you can sign in without verifying.
AUTH_REQUIRE_EMAIL_VERIFICATION="false"

# Google OAuth (OPTIONAL — the "Continue with Google" button only shows if set).
# Where to get it:
#   1. https://console.cloud.google.com/apis/credentials
#   2. "Create Credentials" → "OAuth client ID" → Application type: Web application
#   3. Authorized redirect URI:  http://localhost:3000/api/auth/callback/google
#      (add your production URL's /api/auth/callback/google too)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# GitHub OAuth (OPTIONAL — the "Continue with GitHub" button only shows if set).
# Where to get it:
#   1. https://github.com/settings/developers → "New OAuth App"
#   2. Authorization callback URL:  http://localhost:3000/api/auth/callback/github
#   3. Generate a client secret on the app page
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""


# -----------------------------------------------------------------------------
# Redis — Upstash   (queue + rate limiting; needed to run captures)
# -----------------------------------------------------------------------------
# Where to get it:
#   1. Create a Redis database at https://console.upstash.com
#   2. On the database page, "Connect" → copy the TCP URL that starts with rediss://
#      (BullMQ needs this raw TCP one — not the REST URL)
REDIS_URL="rediss://default:password@your-db.upstash.io:6379"

# Same Upstash database → scroll to the "REST API" section.
# These power the sliding-window rate limiter on the capture endpoint.
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN=""


# -----------------------------------------------------------------------------
# Object storage — Cloudflare R2   (where rendered screenshots are saved)
# -----------------------------------------------------------------------------
# Where to get it (https://dash.cloudflare.com → R2):
#   - R2_ACCOUNT_ID: shown on the R2 overview page (also in the S3 API endpoint URL)
#   - Create a bucket; put its name in R2_BUCKET
#   - "Manage R2 API Tokens" → "Create API Token" (Object Read & Write):
#       gives you the Access Key ID and Secret (the secret is shown only once)
#   - R2_PUBLIC_URL: open the bucket → Settings → enable Public access (r2.dev URL)
#       or connect a custom domain, then paste that base URL here
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="snapsaas-assets"
R2_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"


# -----------------------------------------------------------------------------
# Payments — Lemon Squeezy   (OPTIONAL — only needed for paid plans)
# -----------------------------------------------------------------------------
# Where to get it:
#   - API key:        https://app.lemonsqueezy.com/settings/api → create an API key
#   - Store ID:       Settings → Stores → the numeric ID of your store
#   - Webhook secret: Settings → Webhooks → create a webhook pointing to
#                     https://<your-app>/api/webhooks/lemonsqueezy, set a signing
#                     secret, and paste the same value here
#   - Variant IDs:    Products → your product → each pricing variant has a numeric
#                     ID (visible in the variant URL). Map them below.
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_PRO_MONTHLY_VARIANT_ID=""
LEMONSQUEEZY_PRO_YEARLY_VARIANT_ID=""
LEMONSQUEEZY_TEAM_MONTHLY_VARIANT_ID=""
LEMONSQUEEZY_TEAM_YEARLY_VARIANT_ID=""


# -----------------------------------------------------------------------------
# Email — Resend   (OPTIONAL — welcome + "assets ready" emails)
# -----------------------------------------------------------------------------
# Where to get it:
#   - API key: https://resend.com/api-keys → create
#   - EMAIL_FROM: must use a domain you've verified at https://resend.com/domains.
#       For quick testing before verifying a domain, use: onboarding@resend.dev
RESEND_API_KEY=""
EMAIL_FROM="SnapSaas <onboarding@resend.dev>"

# Where contact-form messages are delivered (and shown on the /contact page).
# If RESEND_API_KEY is blank, the form falls back to opening the user's mail app.
SUPPORT_EMAIL="support@yourdomain.com"


# -----------------------------------------------------------------------------
# Analytics — PostHog   (OPTIONAL)
# -----------------------------------------------------------------------------
# Where to get it: https://app.posthog.com → Project settings → Project API Key.
# (Vercel Analytics works automatically on Vercel with no keys.)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
